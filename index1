<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{
  --lime:#5a8500;--lime-banner:#8fd400;--black:#000000;--white:#ffffff;--gray:#c0c0c0;
  --gray-light:#e8e8e8;--gray-mid:#888888;
  --mono:'DM Mono',monospace;--serif:'Playfair Display',serif;
}
html{scroll-behavior:smooth;}
body{background:var(--white);color:var(--black);font-family:var(--mono);overflow-x:hidden;}
.label{font-size:10px;letter-spacing:.3em;text-transform:uppercase;color:var(--gray-mid);}
.masthead{display:grid;grid-template-columns:1fr auto 1fr;align-items:center;border-bottom:3px solid var(--black);background:var(--white);}
.masthead-img{aspect-ratio:1;max-height:220px;background:#f0f0f0;border-right:2px solid var(--black);display:flex;align-items:center;justify-content:center;flex-direction:column;gap:8px;cursor:pointer;position:relative;overflow:hidden;transition:background .2s;}
.masthead-img:last-child{border-right:none;border-left:2px solid var(--black);}
.masthead-img img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;}
.img-input{display:none;}
.masthead-center{text-align:center;padding:2rem 2.5rem;}
.masthead-sub{font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:var(--gray-mid);margin-bottom:.5rem;}
.masthead-title{font-family:var(--serif);font-size:clamp(4rem,12vw,7rem);font-weight:700;line-height:.9;color:var(--black);letter-spacing:-.02em;}
.masthead-date{font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--gray-mid);margin-top:.75rem;}
.sec-head{border-top:2px solid var(--black);border-bottom:1px solid var(--gray-light);padding:.6rem 2rem;display:flex;align-items:center;justify-content:center;gap:1rem;background:var(--black);}
.sec-head span{font-size:12px;letter-spacing:.25em;text-transform:uppercase;color:var(--lime);}
.banner{background:var(--lime-banner);padding:1.2rem 2rem;display:flex;align-items:center;justify-content:center;gap:1rem;}
.banner-text{font-family:var(--serif);font-size:clamp(1.4rem,4vw,2.2rem);font-weight:700;color:var(--black);line-height:1.1;}
.banner-body{font-size:13px;line-height:1.9;color:var(--black);padding:1.5rem 2rem;max-width:860px;margin:0 auto;}
.content{padding:2.5rem 2rem;max-width:860px;margin:0 auto;}
.content h2{font-family:var(--serif);font-size:1.6rem;font-weight:700;color:var(--black);margin-bottom:1rem;}
.content p{font-size:13px;line-height:2;color:var(--black);margin-bottom:1rem;}

/* DNA MAP + BREAKDOWN LAYOUT */
.dna-layout{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--gray-light);border:1px solid var(--gray-light);margin:1.5rem 0;}
.dna-map{background:var(--white);overflow:hidden;}
.dna-map img{width:100%;height:100%;object-fit:cover;display:block;}
.dna-breakdown{background:var(--white);padding:1.5rem;}
.dna-title{font-size:10px;letter-spacing:.25em;text-transform:uppercase;color:var(--gray-mid);margin-bottom:1.2rem;padding-bottom:.6rem;border-bottom:2px solid var(--lime);}
.dna-row{display:flex;align-items:center;gap:.75rem;padding:.45rem 0;border-bottom:1px dashed var(--gray-light);}
.dna-row:last-child{border-bottom:none;}
.dna-bar-wrap{flex:1;background:#f0f0f0;height:6px;}
.dna-bar{height:6px;background:var(--lime);}
.dna-region{font-size:11px;color:var(--black);line-height:1.4;flex:0 0 auto;max-width:180px;}
.dna-pct{font-size:11px;font-weight:500;color:var(--black);min-width:32px;text-align:right;flex-shrink:0;}

.plotly-slot{border:2px dashed var(--gray-light);background:#fafafa;min-height:260px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px;margin:1.5rem 0;}
.plotly-slot .ps-icon{width:40px;height:40px;background:var(--lime);display:flex;align-items:center;justify-content:center;}
.plotly-slot .ps-label{font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--gray-mid);}
.plotly-slot .ps-note{font-size:11px;color:#bbb;margin-top:4px;}
.single-image{border:1px solid var(--gray-light);margin:1.5rem 0;}
.single-image .img-slot{aspect-ratio:16/7;background:#f8f8f8;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;cursor:pointer;transition:background .2s;position:relative;overflow:hidden;}
.single-image .img-slot:hover{background:#f3ffe0;}
.single-image .img-slot img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:none;}
.single-image .img-slot.has-image img{display:block;}
.single-image .img-slot.has-image .img-placeholder{display:none;}
.img-placeholder{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;}
.img-plus{width:32px;height:32px;background:var(--lime);display:flex;align-items:center;justify-content:center;font-size:20px;color:var(--white);}
.favs-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:0;border:1px solid var(--gray-light);}
.fav-col{border-right:1px solid var(--gray-light);padding:1.5rem;}
.fav-col:last-child{border-right:none;}
.fav-col-head{font-size:10px;letter-spacing:.25em;text-transform:uppercase;color:var(--gray-mid);margin-bottom:1rem;padding-bottom:.6rem;border-bottom:2px solid var(--lime);}
.fav-item{font-size:12px;color:var(--black);padding:.35rem 0;border-bottom:1px dashed var(--gray-light);line-height:1.5;}
.fav-item:last-child{border-bottom:none;}
.fav-item.italic{font-style:italic;color:var(--gray-mid);}
.fave-things{border:1px solid var(--gray-light);overflow:hidden;margin:0;}
.fave-row{display:flex;align-items:baseline;gap:1rem;padding:.85rem 1.5rem;border-bottom:1px solid var(--gray-light);font-size:13px;}
.fave-row:last-child{border-bottom:none;}
.fave-key{font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--lime);min-width:180px;flex-shrink:0;}
.fave-val{color:var(--black);line-height:1.6;}
.facts-grid{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--gray-light);border:1px solid var(--gray-light);}
.fact-card{background:var(--white);padding:1.75rem;}
.fact-num{font-family:var(--serif);font-size:2.5rem;font-weight:700;color:var(--lime);line-height:1;margin-bottom:.5rem;}
.fact-text{font-size:13px;line-height:1.9;color:var(--black);}
.three-things{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--gray-light);border:1px solid var(--gray-light);}
.thing-card{background:var(--white);padding:1.75rem;}
.thing-title{font-family:var(--serif);font-size:1.2rem;font-style:italic;color:var(--black);margin-bottom:.75rem;padding-bottom:.75rem;border-bottom:2px solid var(--lime);}
.thing-body{font-size:12px;line-height:1.9;color:var(--black);}
.thing-body li{list-style:none;padding:.2rem 0;}
.thing-body li::before{content:'\2014 ';color:var(--lime);}
.yt-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--gray-light);border:1px solid var(--gray-light);margin:1.5rem 0;}
.yt-card{background:var(--white);display:flex;flex-direction:column;text-decoration:none;transition:background .2s;}
.yt-card:hover{background:#f3ffe0;}
.yt-thumb{aspect-ratio:16/9;background:#f0f0f0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;border-bottom:1px solid var(--gray-light);}
.yt-play{width:34px;height:34px;background:var(--lime);display:flex;align-items:center;justify-content:center;}
.yt-tri{width:0;height:0;border-top:7px solid transparent;border-bottom:7px solid transparent;border-left:13px solid var(--white);margin-left:3px;}
.yt-thumb-lbl{font-size:9px;letter-spacing:.2em;text-transform:uppercase;color:#bbb;}
.yt-info{padding:.85rem 1rem;}
.yt-title{font-family:var(--serif);font-size:.85rem;font-style:italic;color:var(--black);margin-bottom:3px;line-height:1.4;}
.yt-url{font-size:10px;color:#bbb;word-break:break-all;}
.kpop-rules{border:1px solid var(--gray-light);overflow:hidden;margin:1.5rem 0;}
.kpop-rule{display:flex;gap:1.5rem;padding:1rem 1.5rem;border-bottom:1px solid var(--gray-light);align-items:flex-start;}
.kpop-rule:last-child{border-bottom:none;}
.kpop-rule:hover{background:#f3ffe0;}
.kpop-n{font-family:var(--serif);font-size:1.6rem;font-weight:700;color:var(--lime);min-width:36px;line-height:1;}
.kpop-text{font-size:13px;line-height:1.8;color:var(--black);}
.noodle-banner{background:var(--black);padding:3rem 2rem;display:flex;align-items:center;gap:3rem;position:relative;overflow:hidden;}
.noodle-banner::before{content:'';position:absolute;width:200px;height:200px;background:var(--lime);opacity:.09;right:-40px;top:-40px;transform:rotate(20deg);}
.noodle-emoji{font-size:clamp(3rem,8vw,5rem);flex-shrink:0;}
.noodle-title{font-family:var(--serif);font-size:1.6rem;font-style:italic;color:var(--white);margin-bottom:.4rem;}
.noodle-sub{font-size:12px;letter-spacing:.15em;text-transform:uppercase;color:var(--gray);}
.noodle-list{border:1px solid var(--gray-light);overflow:hidden;margin:1.5rem 0;}
.noodle-item{display:flex;gap:1.5rem;padding:1rem 1.5rem;border-bottom:1px solid var(--gray-light);align-items:flex-start;}
.noodle-item:last-child{border-bottom:none;}
.noodle-dot{width:10px;height:10px;background:var(--lime);flex-shrink:0;margin-top:5px;}
.noodle-text{font-size:13px;line-height:1.8;color:var(--black);}
footer{text-align:center;padding:4rem 2rem;border-top:4px solid var(--lime);}
footer .big{font-family:var(--serif);font-size:clamp(3rem,10vw,6rem);font-weight:700;font-style:italic;color:var(--black);}
footer .sub{font-size:10px;letter-spacing:.25em;text-transform:uppercase;color:var(--gray-mid);margin-top:1rem;display:flex;align-items:center;justify-content:center;gap:10px;}
footer .dot{display:inline-block;width:8px;height:8px;background:var(--lime);}
@media(max-width:640px){
  .masthead{grid-template-columns:1fr;}
  .masthead-img{max-height:160px;}
  .masthead-img:last-child{border-left:none;border-top:2px solid var(--black);}
  .favs-grid,.three-things,.facts-grid,.yt-grid{grid-template-columns:1fr;}
  .fav-col{border-right:none;border-bottom:1px solid var(--gray-light);}
  .noodle-banner{flex-direction:column;gap:1.5rem;}
  .fave-key{min-width:120px;}
  .dna-layout{grid-template-columns:1fr;}
}

.museum-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:4px;}
.museum-img{overflow:hidden;background:#f0f0f0;aspect-ratio:1;}
.museum-img img{width:100%;height:100%;object-fit:cover;display:block;}
.museum-img.tall{aspect-ratio:3/4;}
.museum-img.wide{grid-column:1/-1;aspect-ratio:2/1;}
@media(max-width:640px){.museum-grid{grid-template-columns:1fr 1fr;}.museum-img.wide{grid-column:1/-1;}}
</style>
</head>
